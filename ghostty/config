theme = Tomorrow Night Bright
term = xterm-256color

window-subtitle = working-directory

font-family = "MesloLGM Nerd Font Mono Regular, Sarasa Mono K"
font-size = 15
font-style-bold = false
font-style-bold-italic = false
font-feature = -calt
font-feature = -liga
font-feature = -dlig

shell-integration-features = no-cursor
cursor-style = block
cursor-color = #D3D3D3
cursor-opacity = 0.7

macos-option-as-alt = true
keybind = global:cmd+backquote=toggle_quick_terminal

# Pass through ctrl+shift+d to the terminal (for Neovim)
keybind = ctrl+shift+d=unbind

# Pass through ctrl+period to the terminal (for Neovim)
keybind = ctrl+period=unbind

# notification
bell-features = system

# Pane Navigation
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:down
# keybind = ctrl+k=goto_split:up
# keybind = ctrl+l=goto_split:right

